[
  // ==========================
  // AUTHENTICATION
  // ==========================
  {
    "endpoint": "POST /api/signup",
    "description": "Register a new user",
    "request": {
      "name": "Jane Doe",
      "email": "jane@example.com",
      "password": "password123",
      "password_confirmation": "password123",
      "role": "user"
    },
    "response": {
      "message": "Welcome to ChairPal! Please verify your email with the code we’ve sent to you.",
      "data": []
    }
  },
  {
    "endpoint": "POST /api/login",
    "description": "Login existing user",
    "request": {
      "email": "jane@example.com",
      "password": "password123"
    },
    "response": {
      "message": "Logged in successfully.",
      "data": {
        "data": {
          "id": 1,
          "name": "Jane Doe",
          "email": "jane@example.com",
          "role": "user"
        },
        "access_token": "1|token_string_here...",
        "access_token_expires_in": 7200,
        "remember_token": "2|remember_token_string_here...",
        "remember_token_expires_in": 1209600
      }
    }
  },
  {
    "endpoint": "POST /api/refresh-token",
    "description": "Refresh access token using remember token",
    "request": {},
    "response": {
      "message": "Token Refreshed successfully.",
      "data": {
        "access_token": "3|new_token_string_here...",
        "access_token_expires_in": 7200,
        "remember_token": "2|remember_token_string_here...",
        "remember_token_expires_in": 1209600
      }
    }
  },
  {
    "endpoint": "POST /api/forget-password",
    "description": "Send OTP to reset password",
    "request": {
      "email": "jane@example.com"
    },
    "response": {
      "message": "The Verification code (OTP) has been sent to your email.",
      "data": []
    }
  },
  {
    "endpoint": "POST /api/resend-otp",
    "description": "Resend OTP to reset password",
    "request": {
      "email": "jane@example.com"
    },
    "response": {
      "message": "Verification code (OTP) has been resent successfully.",
      "data": []
    }
  },
  {
    "endpoint": "POST /api/verify-otp",
    "description": "Verify OTP for resetting password",
    "request": {
      "email": "jane@example.com",
      "otp": "123456"
    },
    "response": {
      "message": "Awesome! Your Verification code (OTP) has been verified successfully.",
      "data": []
    }
  },
  {
    "endpoint": "POST /api/reset-password",
    "description": "Reset password using token",
    "request": {
      "email": "jane@example.com",
      "password": "newpassword123",
      "password_confirmation": "newpassword123",
      "token": "valid_reset_token"
    },
    "response": {
      "message": "Password has been reset successfully.",
      "data": []
    }
  },
  {
    "endpoint": "POST /api/resend-verification-code",
    "description": "Resend email verification code",
    "request": {
      "email": "jane@example.com"
    },
    "response": {
      "message": "Code has been resent successfully.",
      "data": []
    }
  },
  {
    "endpoint": "POST /api/verify-email",
    "description": "Verify user email using code",
    "request": {
      "email": "jane@example.com",
      "otp": "1234"
    },
    "response": {
      "message": "Awesome! Your email has been verified successfully.",
      "data": []
    }
  },
  {
    "endpoint": "POST /api/logout",
    "description": "Logout user",
    "request": {},
    "response": {
      "message": "You have been logged out successfully.",
      "data": []
    }
  },
  // ==========================
  // PROFILE
  // ==========================
  {
    "endpoint": "PUT /api/profile/update",
    "description": "Update user profile",
    "request": {
      "name": "Jane Doe updated",
      "phone": "+1234567890",
      "image": "(file upload optional)"
    },
    "response": {
      "message": "Profile updated successfully.",
      "data": {
        "id": 1,
        "name": "Jane Doe updated",
        "phone": "+1234567890"
      }
    }
  },
  {
    "endpoint": "PUT /api/profile/change-password",
    "description": "Change user password",
    "request": {
      "current_password": "password123",
      "password": "newpassword123",
      "password_confirmation": "newpassword123"
    },
    "response": {
      "message": "Password changed successfully.",
      "data": []
    }
  },
  {
    "endpoint": "GET /api/profile/favorites",
    "description": "Get all user favorites",
    "request": {},
    "response": {
      "message": "Favorites retrieved successfully.",
      "data": [
        // List of favorited places and organizations
      ]
    }
  },
  // ==========================
  // ORGANIZATIONS
  // ==========================
  {
    "endpoint": "GET /api/organizations",
    "description": "List organizations. Accepts filters.",
    "request": {
      "category_id": 1,
      "country_id": 2,
      "city_id": 5,
      "has_categories": true,
      "include": "categories,places"
    },
    "response": {
      "message": "Organizations retrieved successfully.",
      "data": [
        {
          "id": 1,
          "name": "Main Org",
          "average_rating": 4.5
        }
      ]
    }
  },
  {
    "endpoint": "POST /api/organizations",
    "description": "Create an organization",
    "request": {
      "name": "New Organization",
      "category_name": "Healthcare",
      "country_name": "USA",
      "city_name": "New York",
      "description": "Accessible Healthcare Org",
      "image": "(file upload optional)"
    },
    "response": {
      "message": "Organization created successfully.",
      "data": {
        "id": 2,
        "name": "New Organization",
        "owner_id": 1
      }
    }
  },
  {
    "endpoint": "GET /api/organizations/{id}",
    "description": "Get a specific organization by ID",
    "request": {
      "include": "places,categories,reviews"
    },
    "response": {
      "message": "Organization retrieved successfully.",
      "data": {
        "id": 1,
        "name": "Main Org"
      }
    }
  },
  {
    "endpoint": "PUT /api/organizations/{id}",
    "description": "Update an organization",
    "request": {
      "name": "Updated Org Name",
      "description": "Updated info"
    },
    "response": {
      "message": "Organization updated successfully.",
      "data": {
        "id": 1,
        "name": "Updated Org Name"
      }
    }
  },
  {
    "endpoint": "DELETE /api/organizations/{id}",
    "description": "Delete an organization",
    "request": {},
    "response": {
      "message": "Organization deleted successfully.",
      "data": []
    }
  },
  {
    "endpoint": "POST /api/organizations/{organization}/reviews",
    "description": "Add a review to an organization",
    "request": {
      "rating": 5,
      "comment": "Great accessible facilities!"
    },
    "response": {
      "message": "Review added successfully.",
      "data": {
        "id": 1,
        "rating": 5,
        "comment": "Great accessible facilities!"
      }
    }
  },
  {
    "endpoint": "POST /api/organizations/{organization}/favorite",
    "description": "Toggle favorite status for an organization",
    "request": {},
    "response": {
      "message": "Added to favorites successfully. (Or Removed)",
      "data": []
    }
  },
  {
    "endpoint": "POST /api/organizations/{organization}/visit",
    "description": "Record a visit to an organization",
    "request": {},
    "response": {
      "message": "Visit recorded successfully.",
      "data": []
    }
  },
  {
    "endpoint": "POST /api/organizations/{organization}/comments",
    "description": "Add a comment to an organization",
    "request": {
      "content": "Is there a parking space inside?"
    },
    "response": {
      "message": "Comment added successfully.",
      "data": {
        "id": 1,
        "content": "Is there a parking space inside?"
      }
    }
  },
  // ==========================
  // PLACES
  // ==========================
  {
    "endpoint": "GET /api/places",
    "description": "List places visible to the user. Accepts filters.",
    "request": {
      "category_id": 2,
      "organization_id": 1,
      "country_id": 2,
      "has_categories": true,
      "include": "categories,organization"
    },
    "response": {
      "message": "Places retrieved successfully.",
      "data": [
        {
          "id": 1,
          "name": "Central Park Path",
          "average_rating": 5.0
        }
      ]
    }
  },
  {
    "endpoint": "POST /api/places",
    "description": "Create a new place",
    "request": {
      "name": "Accessibility Ramp A",
      "category_name": "Ramps",
      "country_name": "USA",
      "city_name": "New York",
      "organization_id": 1,
      "description": "Ramp at the main entrance",
      "image": "(file upload optional)"
    },
    "response": {
      "message": "Place created successfully.",
      "data": {
        "id": 2,
        "name": "Accessibility Ramp A"
      }
    }
  },
  {
    "endpoint": "GET /api/places/{id}",
    "description": "Get a specific place by ID",
    "request": {
      "include": "reviews,organization,categories"
    },
    "response": {
      "message": "Place retrieved successfully.",
      "data": {
        "id": 1,
        "name": "Central Park Path"
      }
    }
  },
  {
    "endpoint": "PUT /api/places/{id}",
